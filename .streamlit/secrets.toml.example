# Copie para `secrets.toml` (gitignored) só em desenvolvimento local.
#
# Produção: ALIEH_ENV=production no ambiente do SO, ou esta chave nos Secrets (Streamlit Cloud):
# ALIEH_ENV = "production"
# Nesse modo, ou define auth abaixo (legacy) ou existem linhas na tabela SQLite `users`
# (ver scripts/create_alieh_user.py); sem um destes a app não inicia.
#
# O ficheiro em dev é `businessdev.db` por defeito (ver `database/config.py`).
# Opcional — só se quiser outro nome local:
# sqlite_filename = "businessdev.db"
#
# Postgres / Supabase: DB_PROVIDER=postgres e URI de ligação (psycopg 3).
# Preferência Supabase: SUPABASE_DB_URL no ambiente ou:
# supabase_db_url = "postgresql://…"   # connection pooling / direct URL do painel
# Alternativas: DATABASE_URL, database_url, postgres_url (ver database/config.py).
#
# Streamlit Community Cloud usa sempre `business.db` (ignora sqlite_filename).
# Outro host “live”: variável de ambiente ALIEH_PRODUCTION=true.
#
# Customer and business data live in SQLite at the project root.
#
# Auditoria (logs/app.log): cadeia de integridade opcional mais forte com segredo:
# ALIEH_LOG_CHAIN_SECRET = "…"  (definir também no ambiente em produção)
#
# Cópias periódicas (ficheiro app.log + export JSON de tabelas login_attempt_audit,
# sku_deletion_audit, price_history) para audit_backups/ ou caminho configurável:
# Env: ALIEH_AUDIT_BACKUP_INTERVAL_SECONDS (mínimo 60; defeito 86400), ALIEH_AUDIT_BACKUP_DIR,
# ALIEH_AUDIT_EXPORT_DIR (espelho opcional), ALIEH_AUDIT_BACKUP_DISABLED=true para desligar.
# Ou: alieh_audit_backup_interval_seconds, alieh_audit_backup_dir, alieh_audit_export_dir neste ficheiro.
#
# Backup binário SQLite (cópia consistente do ficheiro da BD → /backups/db_backups/business_YYYYMMDD_HHMM.db):
# Env: ALIEH_SQLITE_BACKUP_DIR, ALIEH_SQLITE_BACKUP_INTERVAL_SECONDS (mín. 60; defeito 3600),
# ALIEH_SQLITE_BACKUP_KEEP (últimos N; defeito 20), ALIEH_SQLITE_BACKUP_DISABLED=true.
# Ou: alieh_sqlite_backup_dir, alieh_sqlite_backup_interval_seconds, alieh_sqlite_backup_keep neste ficheiro.
#
# Exportação SQLite → JSON/CSV para migração (ex.: Supabase/Postgres), pasta por defeito `/backups/export/`:
# Python: `from database.sqlite_export import export_all_data; export_all_data()`
# Env opcional: ALIEH_SQLITE_EXPORT_ROOT ou segredo `alieh_sqlite_export_root`.
#
# Webhook opcional (SIEM / agregador): envio best-effort em paralelo; o registo local (logs/app.log
# e backup periódico em disco) mantém-se sempre. Sem URL configurada, não há tráfego HTTP.
# Env: ALIEH_AUDIT_WEBHOOK_URL (POST JSON, event_type=critical_audit em cada log_critical_event).
# Opcional: ALIEH_AUDIT_WEBHOOK_DISABLED=true, ALIEH_AUDIT_WEBHOOK_TIMEOUT_SECONDS,
# ALIEH_AUDIT_WEBHOOK_HEADERS_JSON='{"Authorization":"Bearer …"}',
# ALIEH_AUDIT_WEBHOOK_SNAPSHOTS=true para também enviar audit_snapshot após cada export periódico
# (payload maior — só se o endpoint aceitar).
# Secrets equivalentes: alieh_audit_webhook_url, alieh_audit_webhook_disabled, alieh_audit_webhook_timeout_seconds,
# alieh_audit_webhook_headers_json, alieh_audit_webhook_snapshots.
#
# One-off: export DB from Streamlit Cloud (sidebar → "Backup do banco (admin)"):
# allow_database_export = true
# Depois de descarregar business.db para o PC, apagar esta linha ou pôr false.
#
# Autenticação legacy (opcional): só é usada para login quando a tabela `users` está vazia.
# Se existir pelo menos um utilizador em `users`, o login é só na BD (legacy ignorado — ver aviso na app).
# Em dev, sem legacy e sem utilizadores na BD, a app abre sem login.
# Alternativa: variáveis de ambiente ALIEH_AUTH_USERNAME e ALIEH_AUTH_PASSWORD (têm prioridade).
# auth_username = "your-username"
# auth_password = "your-secure-password"
#
# Opcional — identificador estável para auditoria (logs user_id=…; futuro multi-utilizador).
# Env: ALIEH_AUTH_USER_ID (tem prioridade). Ou no TOML: auth_user_id ou [auth] user_id = "…"
#
# Ou secção TOML:
# [auth]
# username = "your-username"
# password = "your-secure-password"
# user_id = "00000000-0000-0000-0000-000000000001"
