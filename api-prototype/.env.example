# Copie para `.env` na raiz do repositório (o motor Python e a API leem DATABASE_URL daí) ou exporte no processo.

# --- Ambiente canónico (development | staging | production) ---
ALIEH_ENV=development

# --- Base de dados (obrigatório em produção na API) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Arranque estrito: falha se não conseguir SELECT 1
# API_PROTOTYPE_STRICT_STARTUP=1

# --- Exposição / gateway (opcional) ---
# Segredo partilhado com o Next (API_PROTOTYPE_INTERNAL_SECRET no web-prototype)
# API_PROTOTYPE_INTERNAL_SECRET=

# Origens de browser permitidas quando o cliente envia Origin (lista CSV)
# API_PROTOTYPE_TRUSTED_ORIGINS=https://app.seudominio.com

# --- Métricas ---
# Em ALIEH_ENV=production, GET /metrics exige ?token=...
# ALIEH_METRICS_SCRAPE_TOKEN=
