# Copy to `.env` or `.env.local` (Next.js). Never commit real values.
# Supabase API values are used by existing scripts/Python utilities.

# --- Protótipo Next (porta 3000) + FastAPI `api-prototype` (porta 8000) ---
# Em `next dev`, se omitir URL/utilizador, o Next usa http://127.0.0.1:8000 e user id "1".
# Suba a API: `npm run dev:api` (na raiz do repo).
API_PROTOTYPE_URL=http://127.0.0.1:8000
API_PROTOTYPE_USER_ID=1
# Opcional em dev: força perfil (senão, em dev sem cookie = admin para cadastros).
# ALIEH_DEV_ROLE=viewer
# Modo aberto (UAT): RBAC nas server actions fica permissivo — só em ambientes controlados.
# ALIEH_PROTOTYPE_OPEN=1

# Root Next (app na raiz): sessão JWT em cookie httpOnly — mínimo 16 caracteres; use 32+ em produção.
AUTH_SESSION_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Login legacy quando a tabela `users` está vazia (defina só no servidor / Vercel; nunca commite a senha).
# ALIEH_AUTH_USERNAME=admin
# ALIEH_AUTH_PASSWORD=
# Opcional: id numérico enviado à API como X-User-Id quando só existe login legacy.
# ALIEH_AUTH_USER_ID=1

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# web-prototype: client uploads directly to Storage using signed URL from api-prototype (same project).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional display name for X-Username when ALIEH_PROTOTYPE_OPEN=1 (UAT / audit).
API_PROTOTYPE_USERNAME=dev-operator

# api-prototype: mint signed upload URLs only (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Bucket must exist and be public if you use getPublicUrl / product_image_storage_url validation.
SUPABASE_STORAGE_PRODUCT_IMAGES_BUCKET=product-images

# GitHub Actions: no repositório, crie o secret ALIEH_CI_DATABASE_URL com a connection string Postgres
# (Supabase dedicado a CI/QA — nunca produção). O workflow exporta-a como DATABASE_URL.

# Shared secret so Next.js (web-prototype) can POST /audit/login-ingest before a session exists.
# Must match api-prototype env when using login DB audit.
PROTOTYPE_AUDIT_INGEST_SECRET=change-me-long-random-string

# Server-only database connection for the Next.js prototype.
# Prefer the Supabase pooler URL for Vercel/serverless deployments.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
# Opcional (Render/regiões distantes): timeout TCP na ligação Postgres em segundos (3–120; defeito 15).
# POSTGRES_CONNECT_TIMEOUT=30

# Plano C (produção Streamlit + Next na mesma BD): mesmo DATABASE_URL que o Streamlit
# e ALIEH_TENANT_ID=default (ou o mesmo tenant_id que o Streamlit usa no login).
# Não uses um tenant só para o Next — isso seria Plano B, não C.
ALIEH_TENANT_ID=default
