# Copie para `.env.local` (gitignored). Next.js carrega automaticamente na raiz de `web-prototype/`.
#
# Tier: development | staging | production (validação estrita em produção — ver `lib/env/alieh-runtime.ts`).
# ALIEH_ENV=development
#
# Porta fixa do protótipo (alinhado a `npm run dev` → `next dev -p 3000`).
PORT=3000

# Mesmo par legacy que o Streamlit: env `ALIEH_AUTH_*` ou `.streamlit/secrets.toml` (`auth_username` / `auth_password`).
# Mantenha em sincronia com o ficheiro de secrets que usa em produção / Cloud.
ALIEH_AUTH_USERNAME=
ALIEH_AUTH_PASSWORD=

# JWT da sessão do protótipo (obrigatório para login).
AUTH_SESSION_SECRET=

# API FastAPI de protótipo (obrigatório para vendas, clientes, etc. via servidor).
# Tem de ser a URL da api-prototype (uvicorn), NÃO a do Next (não use :3000 aqui).
API_PROTOTYPE_URL=http://127.0.0.1:8000

# Opcional: mesmo valor que `API_PROTOTYPE_INTERNAL_SECRET` na api-prototype (rede interna).
# API_PROTOTYPE_INTERNAL_SECRET=

# Postgres (mesmo `DATABASE_URL` que o app Python, se aplicável).
# DATABASE_URL=

# Supabase (só se usar upload de imagens / cliente browser).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
